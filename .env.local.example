# Notion (공지 DB 연동)
NOTION_TOKEN=
NOTION_NOTICE_DB_ID=

# Contact 폼 이메일 발송용 Resend
RESEND_API_KEY=

# === SOLAPI 알림톡 (로마드협동조합 채널) ===
# 톡투비즈 = SOLAPI 재판매사. SOLAPI 콘솔에서 발급
SOLAPI_API_KEY=
SOLAPI_API_SECRET=

# SMS 발신번호 (사전 등록한 번호)
SOLAPI_SENDER=

# 로마드협동조합 카카오 비즈니스 채널 pfId
# SOLAPI 콘솔 > 카카오 > 발신프로필에서 확인
SOLAPI_KAKAO_CHANNEL_ID=

# 테스트 모드 (실제 발송 안 하고 콘솔 로그만)
# true/false
SOLAPI_TEST_MODE=true

# === FormPay → lomad-homepage webhook 인증용 ===
# FormPay 대시보드에 동일한 값을 입력해야 함
# openssl rand -hex 32 로 생성 추천
FORMPAY_WEBHOOK_SECRET=

# === 현남생활 페스티벌 접수 (forma Supabase 프로젝트 / festival 스키마) ===
SUPABASE_URL=https://inzedtnpbwxwihlvsvhl.supabase.co
# forma 프로젝트 Settings > API > service_role secret (server-only, 절대 클라 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
# 관리자 명단 페이지 비밀번호
FESTIVAL_ADMIN_PASSWORD=
# OTP 코드 해싱 pepper (openssl rand -hex 32)
FESTIVAL_OTP_SECRET=
